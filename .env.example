# ==================== NextAuth.js ====================
# URL приложения (измените на ваш домен в production)
NEXTAUTH_URL=http://localhost:3000

# Секретный ключ для подписи JWT (сгенерируйте: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-here

# ==================== Database ====================
# SQLite для локальной разработки
DATABASE_URL="file:./dev.db"

# PostgreSQL для production (раскомментируйте и настройте)
# DATABASE_URL="postgresql://user:password@localhost:5432/nes_emulator?schema=public"

# ==================== GitHub OAuth (опционально) ====================
# Создайте OAuth приложение на https://github.com/settings/developers
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ==================== Google OAuth (опционально) ====================
# Создайте OAuth приложение на https://console.developers.google.com
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==================== Environment ====================
# Режим работы (development, production)
NODE_ENV=development

# Порт для dev сервера (если отличается от 3000)
# PORT=3000

# ==================== Upload Settings ====================
# Максимальный размер загружаемого файла (в байтах)
# MAX_UPLOAD_SIZE=10485760

# Папка для загруженных ROM файлов
# UPLOAD_DIR=./upload

# ==================== CORS (для API) ====================
# Разрешённые источники для CORS
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
